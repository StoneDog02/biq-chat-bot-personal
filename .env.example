# ---------------------------------------------------------------------------
# BODYiQ AI Assistant — environment variables
# Copy this file to `.env.local` for local dev, and configure the same keys in
# the Vercel project settings for production. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Anthropic (Claude) ---
# TODO: create a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional override; defaults to "claude-sonnet-5" in src/lib/anthropic.ts
ANTHROPIC_MODEL=claude-sonnet-5

# --- Voyage AI (embeddings) ---
# TODO: create a key at https://dashboard.voyageai.com/
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional override; defaults to "voyage-3" (1024-dim) in src/lib/embeddings.ts
VOYAGE_MODEL=voyage-3

# --- Supabase ---
# TODO: from your Supabase project settings → API. Put REAL values in .env.local
# (git-ignored), never here.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# SERVICE ROLE key — server-side only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...

# --- Shopify Admin API ---
# TODO: from the app's Settings page in the Dev Dashboard → Client credentials.
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxx
# The *.myshopify.com domain (NOT the public storefront domain)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2026-07

# --- Backfill / admin auth ---
# Bearer token required to trigger the /api/ingest/backfill route in production.
# TODO: generate a long random string (e.g. `openssl rand -hex 32`).
BACKFILL_ADMIN_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS / widget ---
# The public storefront origin allowed to call /api/chat.
ALLOWED_ORIGIN=https://bodyiq.com
# The origin the compiled widget bundle (widget.js / widget.css) is served from.
# Used by the Liquid snippet to know where to fetch assets, and by /api/chat's
# CORS allow-list alongside ALLOWED_ORIGIN. This one is exposed to the browser.
NEXT_PUBLIC_WIDGET_ORIGIN=https://biq-chat-bot-personal.vercel.app