{%- comment -%}
  BODYiQ AI Assistant — theme snippet
  ------------------------------------------------------------------
  Drop this file at snippets/ai-chat-widget.liquid, then render it once per page
  (e.g. near the end of theme.liquid, or inside product/article templates):

      {% render 'ai-chat-widget' %}

  The widget renders as a FLOATING, bottom-right launcher (it is position:fixed,
  so it no longer matters exactly where in the template you render it — it will
  not affect page layout). It loads the compiled bundle (widget.js / widget.css)
  from the origin where this service is deployed and initializes it with the
  current page's context inferred from Liquid template objects.

  CONFIG — the asset origin is NOT hardcoded. Set a theme setting named
  `assistant_origin` (Online Store → Themes → Customize → Theme settings, or in
  settings_schema.json) to the value of NEXT_PUBLIC_WIDGET_ORIGIN from the
  service's environment (e.g. https://assistant.bodyiq.com). The default below
  is only a last-resort fallback.
{%- endcomment -%}

{%- comment -%} Set assistant_origin WITHOUT a trailing slash (e.g. https://assistant.bodyiq.com). {%- endcomment -%}
{%- assign assistant_origin = settings.assistant_origin | default: 'https://assistant.bodyiq.com' | strip -%}

{%- comment -%}
  Infer page context + contextual quick replies from the template.

  peekMessage drives the auto "peek" launcher (a small contextual card that
  surfaces above the pill after dwell/scroll). It is OPTIONAL: when it is not
  set for a given product/article, we omit the key entirely and the peek simply
  never triggers on that page (we never show a peek with generic copy).

  TODO(bodyiq): decide which metafield holds the peek line and replace the
  placeholder namespace/key below. The placeholder used here is
  `metafields.custom.assistant_peek` (a single-line text metafield) — this is a
  GUESS, do not treat it as final. Once you pick the real namespace/key (and
  create the metafield definition in Shopify admin), update both branches.

  Optional: you could also expose a per-page dwell override via another
  metafield mapped to `peekTriggerSeconds` (number). Left out for now — flag if
  you want it wired up.
{%- endcomment -%}
{%- capture page_context_json -%}
  {%- if template.name == 'product' -%}
    {%- assign peek_message = product.metafields.custom.assistant_peek | default: '' | strip -%}{%- comment -%} TODO(bodyiq): confirm metafield key {%- endcomment -%}
    {"type":"product","handle":{{ product.handle | json }}
    {%- if peek_message != '' -%},"peekMessage":{{ peek_message | json }}{%- endif -%}
    }
  {%- elsif template.name == 'article' -%}
    {%- assign peek_message = article.metafields.custom.assistant_peek | default: '' | strip -%}{%- comment -%} TODO(bodyiq): confirm metafield key {%- endcomment -%}
    {"type":"blog","handle":{{ article.handle | json }}
    {%- if peek_message != '' -%},"peekMessage":{{ peek_message | json }}{%- endif -%}
    }
  {%- else -%}
    null
  {%- endif -%}
{%- endcapture -%}

{%- capture quick_replies_json -%}
  {%- if template.name == 'product' -%}
    ["Is this right for me?","How do I take it?","What's in it?","Talk to a person"]
  {%- elsif template.name == 'article' -%}
    ["Summarize this article","Which product fits this?","Ask a follow-up"]
  {%- else -%}
    ["Help me pick a product","How do your supplements work?","Shipping & returns"]
  {%- endif -%}
{%- endcapture -%}

<link rel="stylesheet" href="{{ assistant_origin }}/widget.css">

<div id="bodyiq-assistant" class="bodyiq-assistant-mount"></div>

<script src="{{ assistant_origin }}/widget.js" defer></script>
<script>
  (function () {
    var origin = {{ assistant_origin | json }};
    var config = {
      target: '#bodyiq-assistant',
      apiUrl: origin + '/api/chat',
      pageContext: {{ page_context_json | strip }},
      quickReplies: {{ quick_replies_json | strip }},
      title: 'Ask BODYiQ',
      humanHandoffUrl: {{ routes.root_url | append: '/pages/contact' | json }}
    };
    // widget.js is deferred, so it has executed by the time window 'load' fires.
    window.addEventListener('load', function () {
      if (window.BODYiQAssistant) window.BODYiQAssistant.init(config);
    });
  })();
</script>
